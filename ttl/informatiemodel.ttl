# =============================================================================
# Abstracte elementen
#
# De elementdefinities (GG.EE) waarvan de rubrieken (CC.GG.EE)
# categorie-specifieke instanties zijn.
# =============================================================================

brpelm:anummer a brp:Element ;
    rdfs:label "A-nummer"@nl ;
    rdfs:comment "Het administratienummer (A-nummer), bedoeld in artikel 4.9 van de Wet BRP. Een uniek 10-cijferig nummer dat een persoonslijst identificeert."@nl .

brpelm:aanduidingEuropeesKiesrecht a brp:Element ;
    rdfs:label "Aanduiding Europees kiesrecht"@nl ;
    rdfs:comment "Aanduiding Europees kiesrecht: of de ingeschrevene deelneemt aan EP-verkiezingen in Nederland."@nl .

brpelm:aanduidingBijHuisnummer a brp:Element ;
    rdfs:label "Aanduiding bij huisnummer"@nl ;
    rdfs:comment "Een aanduiding bij het huisnummer (by = tegenover, to = naast)."@nl .

brpelm:aanduidingBijzonderNederlanderschap a brp:Element ;
    rdfs:label "Aanduiding bijzonder Nederlanderschap"@nl ;
    rdfs:comment "Aanduiding bijzonder Nederlanderschap: B (behandeld als Nederlander) of V (vastgesteld niet-Nederlander)."@nl .

brpelm:aanduidingGegevensInOnderzoek a brp:Element ;
    rdfs:label "Aanduiding gegevens in onderzoek"@nl .

brpelm:aanduidingInhoudingVermissingNederlandsReisdocument a brp:Element ;
    rdfs:label "Aanduiding inhouding/vermissing Nederlands reisdocument"@nl ;
    rdfs:comment "Aanduiding of het reisdocument is ingehouden (I) of vermist (V)."@nl .

brpelm:aanduidingNaamgebruik a brp:Element ;
    rdfs:label "Aanduiding naamgebruik"@nl ;
    rdfs:comment "Aanduiding naamgebruik: hoe de naam in het maatschappelijk verkeer wordt gebruikt (E, P, V, N)."@nl .

brpelm:aanduidingUitgeslotenKiesrecht a brp:Element ;
    rdfs:label "Aanduiding uitgesloten kiesrecht"@nl ;
    rdfs:comment "Aanduiding of de ingeschrevene is uitgesloten van het kiesrecht."@nl .

brpelm:aanduidingVerblijfstitel a brp:Element ;
    rdfs:label "Aanduiding verblijfstitel"@nl ;
    rdfs:comment "De aanduiding van de verblijfstitel (code uit Tabel 56)."@nl ;
    rdfs:range brp:VerblijfstitelType .

brpelm:aanhef a brp:Element ;
    rdfs:label "Aanhef"@nl ;
    rdfs:comment "Aanhef voor brieven, afgeleid van naam, geslacht en partnernaam."@nl .

brpelm:aanspreeknaam a brp:Element ;
    rdfs:label "Aanspreeknaam"@nl ;
    rdfs:comment "Naamdeel van de aanschrijfwijze."@nl .

brpelm:aanspreekvorm a brp:Element ;
    rdfs:label "Aanspreekvorm"@nl ;
    rdfs:comment "Vorm van aanspreken onderdeel van de aanschrijfwijze."@nl .

brpelm:aanwijzing a brp:Element ;
    rdfs:label "Aanwijzing"@nl ;
    rdfs:comment "Aanwijzing op de persoonslijst."@nl .

brpelm:adellijkeTitelPredicaat a brp:Element ;
    rdfs:label "Adellijke titel/predicaat"@nl ;
    rdfs:comment "Een code uit Tabel 38 (Adellijke titel/predicaat) die aangeeft welke titel of welk predicaat tot de naam behoort."@nl .

brpelm:adresEULidstaatVanHerkomst a brp:Element ;
    rdfs:label "Adres EU-lidstaat van herkomst"@nl ;
