# =============================================================================
# BRP Informatiemodel
#
# Categorieën, groepen en elementen van de Basisregistratie Personen.
# Gebaseerd op het Logisch Ontwerp BRP 2024.Q2, Deel 4.
# =============================================================================


# =============================================================================
# Categorie 01/51 — Persoon
#
# Gegevens over de ingeschrevene.
# =============================================================================

brpcat:persoon a odrl:AssetCollection,
        brp:Categorie ;
    rdfs:label "Persoon"@nl ;
    rdfs:comment "Gegevens over de ingeschrevene."@nl ;
    skos:notation "01" .

brpcat:persoonHist a odrl:AssetCollection,
        brp:Categorie ;
    rdfs:label "Persoon (historisch)"@nl ;
    rdfs:comment "Historische variant: gegevens over de ingeschrevene."@nl ;
    skos:notation "51" ;
    brp:historischeVariantVan brpcat:persoon .

# --- Groep 01.01: Identificatienummers ---

brpgrp:persoon-identificatienummers a odrl:AssetCollection,
        brp:Groep ;
    rdfs:label "Identificatienummers"@nl ;
    skos:notation "01.01" ;
    odrl:partOf brpcat:persoon ;
    brp:behoortTotCategorie brpcat:persoon .

brprub:anummerPersoon a brp:Rubriek ;
    rdfs:label "A-nummer (Persoon)"@nl ;
    odrl:partOf brpgrp:persoon-identificatienummers ;
    brp:behoortTotGroep brpgrp:persoon-identificatienummers ;
    brp:element brpelm:anummer ;
    brp:rubrieknummer "01.01.10" .

brprub:burgerservicenummerPersoon a brp:Rubriek ;
